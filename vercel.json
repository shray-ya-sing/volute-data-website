{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/pdf.ts": {
      "memory": 1024,
      "maxDuration": 120,
      "includeFiles": "api/vendor/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-new-filings",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/submit-batch",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/poll-batches",
      "schedule": "*/2 * * * *"
    }
  ]
}
