# Anthropic API Key for query parsing (server-side)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Neon Database Connection
# Get from: https://console.neon.tech/ -> Project -> Connection Details
# Use "Pooled connection" for serverless functions
POSTGRES_URL=postgresql://user:password@host.neon.tech/volute?sslmode=require
POSTGRES_PRISMA_URL=postgresql://user:password@host.neon.tech/volute?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://user:password@host.neon.tech/volute?sslmode=require

# Vercel Blob Storage
# Will be automatically set by Vercel when you enable Blob
# For local dev, create a store at: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=vercel_blob_token_here

# Admin Panel Password
# Set a secure password for accessing /admin
ADMIN_PASSWORD=change_this_secure_password
